{
  "name": "ai-dev-server",
  "version": "0.1.0",
  "description": "CLI tool that generates, runs, and hot-reloads Express.js backends from natural language prompts.",
  "type": "module",
  "main": "dist/src/cli.js",
  "bin": {
    "ai-dev-server": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/test/parser.test.js dist/test/snapshot.test.js",
    "format": "prettier --write ."
  },
  "keywords": [
    "cli",
    "nodejs",
    "express",
    "openai",
    "openrouter",
    "developer-tools",
    "code-generation",
    "generation",
    "scaffolding"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
